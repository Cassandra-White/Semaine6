$logName = "BillU"
$source  = "BillU-Scripts"

if (-not [System.Diagnostics.EventLog]::SourceExists($source)) {
    New-EventLog -LogName $logName -Source $source
    Write-Host "[OK] Journal '$logName' créé." -ForegroundColor Green
}


# Tester en ecrivant un evenement manuellement
Write-EventLog -LogName $logName -Source $source `
    -EventId 1000 -EntryType Information `
    -Message "BillU-Scripts : journal configure avec succes"

# Verifier dans l Observateur d evenements
Get-EventLog -LogName $logName -Newest 3 | Format-Table TimeGenerated, EntryType, Message -Wrap
